{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@shared-types": ["../packages/shared-types"],
      "@shared-api": ["../packages/shared-api"],
      "@shared-auth": ["../packages/shared-auth"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../packages/**/*"
  ]
}
